# Frontend Environment Variables
# Copy file ini menjadi .env.local untuk development lokal

# Supabase (bisa pakai anon key — aman untuk frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# URL frontend ini sendiri (untuk OAuth redirect)
VITE_SITE_URL=https://novelora.my.id

# URL Backend API (Cloudflare Worker di akun thedarkcube313)
# Production: https://api.novelora.my.id
# Development: http://localhost:8787
VITE_API_URL=https://api.novelora.my.id
